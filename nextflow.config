params {
    input          = "samplesheet.csv"
    outdir         = "results"
    reference      = "assets/reference.fa"
    markers        = "assets/markers.tsv"
    min_depth      = 10
    min_qual       = 20
    threads        = 4
    multiqc_config = "assets/multiqc_config.yaml"
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    maxRetries = 1

    withName: FASTQC_RAW {
        publishDir = "${params.outdir}/qc/raw", mode: 'copy'
    }

    withName: FASTP {
        publishDir = "${params.outdir}/trimmed", mode: 'copy'
    }

    withName: FASTQC_TRIMMED {
        publishDir = "${params.outdir}/qc/trimmed", mode: 'copy'
    }

    withName: ALIGN {
        publishDir = "${params.outdir}/alignment", mode: 'copy'
    }

    withName: BAM_QC {
        publishDir = "${params.outdir}/bam_qc", mode: 'copy'
    }

    withName: VARIANT_CALL {
        publishDir = "${params.outdir}/variants", mode: 'copy'
    }

    withName: CONSENSUS {
        publishDir = "${params.outdir}/consensus", mode: 'copy'
    }

    withName: CLASSIFY_VACCINE {
        publishDir = "${params.outdir}/classification/per_sample", mode: 'copy'
    }

    withName: AGGREGATE_CLASSIFICATION {
        publishDir = "${params.outdir}/classification", mode: 'copy'
    }

    withName: BUILD_REPORT_ASSETS {
        publishDir = "${params.outdir}/report/assets", mode: 'copy'
    }

    withName: MULTIQC {
        publishDir = "${params.outdir}/report", mode: 'copy'
    }
}

profiles {
    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled = true
        docker.enabled = false
    }

    test {
        params {
            input = "testdata/samplesheet.csv"
            outdir = "test_results"
        }
    }
}
